# PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/pos_db?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pos_db?schema=public"

# Secret used to sign admin session tokens (generate with: openssl rand -base64 32)
SESSION_SECRET="change-this-to-a-long-random-string"

# Seed admin credentials (used only by `npm run db:seed`)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"
